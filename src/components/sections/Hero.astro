---
import type { Basics } from "@/types";
import Section from "@/components/Section.astro";
import Mail from "@/icons/Mail.astro";
import Phone from "@/icons/Phone.astro";
import Phone2 from "@/icons/Phone2.astro";
import GitHub from "@/icons/GitHub.astro";
import LinkedIn from "@/icons/LinkedIn.astro";
import WorldMap from "@/icons/WorldMap.astro";

interface Props {
	basics: Basics;
	labels: {
		email: string;
		phone: string;
		phone2: string;
		linkedin: string;
		mailTitle: string;
		phoneTitle: string;
		socialTitle: string;
	};
}

const { basics, labels } = Astro.props;
const { name, label, image, location, profiles, phone, phone2, email } = basics;
const { city, region } = location;
const SOCIAL_ICONS: Record<string, any> = {
	GitHub,
	LinkedIn,
};

const lkInInfo = profiles.find(({ network }) => network === "LinkedIn");
const lkUrl = lkInInfo?.url;
---

<Section>
	<div class="container">
		<div class="info">
			<h1 style="margin-bottom:0; line-height: 1;">{name}</h1>
			<h2 style="margin:0;">{label}</h2>
			<span>
				<WorldMap />
				{city}, {region}
			</span>
			<footer class="no-print">
				{
					email && (
						<a
							href={`mailto:${email}`}
							title={`${labels.mailTitle} ${name} (${email})`}
							target="_blank"
						>
							<Mail />
						</a>
					)
				}
				{
					phone && (
						<a
							href={`tel:${phone}`}
							title={`${labels.phoneTitle} ${name} (${phone})`}
							target="_blank"
						>
							<Phone />
						</a>
					)
				}
				{
					phone2 && (
						<a
							href={`tel:${phone2}`}
							title={`${labels.phoneTitle} ${name} (${phone2})`}
							target="_blank"
						>
							<Phone2 />
						</a>
					)
				}
				{
					profiles.map(({ network, url }) => {
						const Icon = SOCIAL_ICONS[network];

						return (
							<a
								href={url}
								title={`${labels.socialTitle} ${name} ${network}`}
								target="_blank"
								rel="noopener noreferrer"
							>
								<Icon />
							</a>
						);
					})
				}
			</footer>
			<p>{labels.email}: {email}</p>
			<p>{labels.phone}: {phone}</p>
			{
				phone2 && (
					<p>
						{labels.phone2}: {phone2}
					</p>
				)
			}
			<p>{labels.linkedin}: {lkUrl}</p>
		</div>
		<figure>
			<img src={image} alt={name} />
		</figure>
	</div>
</Section>

<style>
	.container {
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.info {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding-right: 32px;
	}

	img {
		aspect-ratio: 1 / 1;
		object-fit: contain;
		width: 128px;
		border-radius: 16px;
	}

	span {
		color: #666;
		display: flex;
		align-items: center;
		gap: 0.25rem;
		font-size: 0.85rem;
		letter-spacing: -0.05rem;
	}

	footer {
		color: #555;
		font-size: 0.65rem;
		display: flex;
		gap: 4px;
		margin-top: 8px;
	}

	footer a {
		color: #777;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border: 1px solid #eee;
		padding: 4px;
		height: 32px;
		width: 32px;
		border-radius: 6px;
		transition: all 0.3s ease;
	}

	footer a:hover {
		background: #eee;
		border: 1px solid #ddd;
	}

	@media (width <= 700px) {
		.container {
			flex-direction: column-reverse;
		}

		.info {
			justify-content: center;
			align-items: center;
			padding-right: 0;
			text-align: center;
		}

		figure {
			display: flex;
			justify-content: center;
			align-items: center;
			margin: 0 auto;
		}

		h2 {
			text-wrap: balance;
		}
	}
</style>
