---
import GitHub from "@/icons/GitHub.astro";
import Section from "@/components/Section.astro";
import type { Project } from "@/types";

interface Props {
	title: string;
	projects: Project[];
}

const { title, projects } = Astro.props;
---

<Section title={title}>
	<ul>
		{
			projects.map(
				({ name, isActive, description, highlights, url, github, image }) => {
					return (
						<li>
							<article>
								<header>
									<h3>
										{name}
									</h3>
									<a style="margin: 8px;" href={url} title={`Ver proyecto ${name}`}>{url}</a>
									{image && (
										<a href={url} title={`Ver proyecto ${name}`}>
											<figure>
												<img src={image} alt={name} />
											</figure>
										</a>
									)}
									<p>{description}</p>
									{github && (								
									<h5><GitHub /> Repositorio:</h5>
										<a
											href={github}
											target="_blank"
											title={`Ver código fuente del proyecto ${name}`}
										>
										{github}
										</a>
									)}
								</header>
								<footer>
									{highlights.map((highlight) => {
										return <span>{highlight}</span>;
									})}
								</footer>
							</article>
						</li>
					);
				},
			)
		}
	</ul>
</Section>
<style>
	ul {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	article {
		border-radius: 8px;
		border: 1px solid #f2f2f2;
		gap: 16px;
		display: flex;
		flex-direction: column;
		padding: 16px;
		height: 100%;
		align-items: center;
		text-align: center;
	}

	article header {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	article h3 {
		margin-bottom: 4px;
	}

	article a {
		color: #111;
	}

	article a:hover {
		text-decoration: underline;
	}

	article p {
		font-size: 0.75rem;
		line-height: 1.2rem;
		margin-bottom: 4px;
		text-align: justify;
	}

	article h3 span {
		color: rgb(0, 188, 47);
		animation-name: flicker;
		animation-duration: 3s;
		animation-timing-function: ease-in;
		animation-iteration-count: infinite;
	}

	figure {
		margin: 0;
		padding: 0;
		display: flex;
		justify-content: center;
	}

	img {
		aspect-ratio: 1 / 1;
		object-fit: contain;
		width: 128px;
		border-radius: 16px;
	}

	footer {
		display: flex;
		flex-wrap: wrap;
		gap: 4px;
		font-size: 0.6rem;
		justify-content: center;
	}

	footer span {
		border-radius: 6px;
		background: #eee;
		color: #444;
		font-size: 0.6rem;
		font-weight: 500;
		padding: 0.2rem 0.6rem;
	}

	.github-code-link {
		margin-top: 8px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 4px;
	}

	@keyframes flicker {
		0% {
			opacity: 1;
		}
		50% {
			opacity: 0.25;
		}
		100% {
			opacity: 1;
		}
	}

	@media (width <= 700px) {
		ul {
			margin-inline: 0px;
		}

		article {
			border: none;
			box-shadow: 0 1px 1px #f2f2f2;
			padding: 0 0 16px 0;
		}
	}

	@media print {
		article h3 span {
			animation-name: none;
		}
	}
</style>
