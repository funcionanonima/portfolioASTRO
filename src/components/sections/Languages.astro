---
import Section from "../Section.astro";
import type { Language } from "@/types";

interface Props {
  title: string;
  languages: Language[];
}

const { title, languages } = Astro.props;
---

<Section title={title}>
  <ul>
    {
      languages.map(({ language, fluency }) => {
        return (
          <li>
            <article>
              <header>
                <div>
                  <h3>{language}</h3>
                </div>
              </header>

              <footer>
                <p>{fluency}</p>
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: row;
    gap: 64px;
    justify-content: center;
    flex-wrap: wrap;
  }

  article h3 {
    font-weight: 500;
    color: #111;
  }

  time {
    color: #555;
    font-size: 0.85rem;
    min-width: 102px;
  }

  @media (width <= 700px) {
    time {
      text-align: right;
    }
  }
</style>
